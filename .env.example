# ============================================================
# Brota — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# ============================================================

# ---------- Supabase ----------
# URL do seu projeto: Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave anon (pública) — usada pelo frontend
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave service_role (privada!) — usada pelo backend APENAS
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret: Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=super-secret-jwt-secret-from-supabase

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-...

# ---------- WhatsApp Cloud API (Meta) ----------
# App criado em developers.facebook.com > Meus Apps > Criar App > "Outro" > "Empresa"
# Adicione o produto "WhatsApp" e, para multi-tenant, configure o Embedded Signup
# (WhatsApp > Configuração da API > Embedded Signup) para gerar o META_CONFIG_ID.
META_APP_ID=000000000000000
META_APP_SECRET=sua-app-secret-da-meta

# Config ID do fluxo de Embedded Signup (WhatsApp > Configuração da API > Embedded Signup)
META_CONFIG_ID=000000000000000

# Token permanente de um System User (Configurações do Negócio > Usuários do sistema)
# com permissão whatsapp_business_management e whatsapp_business_messaging,
# concedido a este App. Usado para enviar mensagens em nome de todas as WABAs conectadas.
META_SYSTEM_USER_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token arbitrário que você escolhe e cadastra também no webhook do App na Meta
# (WhatsApp > Configuração > Webhook > Verify Token)
WEBHOOK_VERIFY_TOKEN=escolha-um-token-secreto

# Versão da Graph API (opcional, padrão v21.0)
GRAPH_API_VERSION=v21.0

# ---------- Stripe ----------
# Chave secreta: dashboard.stripe.com > Desenvolvedores > Chaves de API
STRIPE_SECRET_KEY=sk_test_...

# Signing secret do endpoint de webhook: dashboard.stripe.com > Desenvolvedores > Webhooks
# Endpoint a cadastrar: {BACKEND_URL}/billing/webhook
# Eventos: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# ID do Price recorrente mensal de R$127 (Produto > Preços, no dashboard do Stripe)
STRIPE_PRICE_ID=price_...

# ---------- Backend ----------
# Teto de respostas de IA por empresa/mês (protege contra picos de custo de OpenAI).
# Opcional — padrão 2000 se não definido.
AI_MONTHLY_MESSAGE_LIMIT=2000

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# URL pública do backend (para configurar o callback de webhook na Meta: {BACKEND_URL}/webhook)
BACKEND_URL=http://localhost:8000

# ---------- Frontend (Vite — prefixo VITE_ obrigatório) ----------
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_API_URL=http://localhost:8000

# Mesmo App ID/Config ID configurados acima, expostos ao frontend para o botão
# de Embedded Signup (SDK JS do Facebook)
VITE_META_APP_ID=000000000000000
VITE_META_CONFIG_ID=000000000000000
